    "      const botonSecundario = document.querySelector(`.boton-acceso-secundario.${{seccion}}`);\n",
    "      if (botonPrincipal) botonPrincipal.classList.add('activo');\n",
    "      if (botonSecundario) botonSecundario.classList.add('activo');\n",
    "      \n",
