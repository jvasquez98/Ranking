    "        ctx.font = '16px Arial';\n",
    "        ctx.fillText(`Año: ${{año}}`, canvas.width / 2, canvas.height / 2 + 20);\n",
    "    }}\n",
    "\n",
    "    // ========== FUNCIONES PARA SECCION EVALUACION ========== \n",
    "    function setVistaEvaluacion(tipo) {{\n",
