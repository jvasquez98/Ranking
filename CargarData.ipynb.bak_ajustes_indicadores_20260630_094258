    "        \n",
    "        // Verificar si html2canvas está disponible, si no, cargarlo dinámicamente\n",
    "        function cargarHtml2CanvasSiEsNecesario() {{\n",
    "            if (typeof html2canvas === 'undefined') {{\n",
    "                const script = document.createElement('script');\n",
