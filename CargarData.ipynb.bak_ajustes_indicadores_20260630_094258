    "            return;\n",
    "          }}\n",
    "        \n",
    "          const close = e.target?.closest?.('[data-close=\"1\"]');\n",
    "          if (close) {{\n",
    "            _closeModalEval();\n",
    "          }}\n",
    "        }});\n",
    "        \n",
    "        // Escape con ESC\n",
    "        document.addEventListener('keydown', (e) => {{\n",
    "          if (e.key === 'Escape') _closeModalEval();\n",
    "        }});\n",
    "\n",
    "</script>\n",
    "</body>\n",
