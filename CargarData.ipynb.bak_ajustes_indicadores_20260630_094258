    "            actualizarTarjetasEvaluacionRapida(supervisor);\n",
    "            calcularPeriodoPrueba();\n",
    "        }} else if (seccionActiva.id === 'seccion-calidad') {{\n",
    "            actualizarCalidad(supervisor);\n",
    "        }} else if (seccionActiva.id === 'seccion-gestiones') {{\n",
