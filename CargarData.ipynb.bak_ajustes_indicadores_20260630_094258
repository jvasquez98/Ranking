    "def extraer_datos_mundial_me(ruta_excel, base_path):\n",
    "    \"\"\"Extrae la actividad mundialista desde la hoja ME.\"\"\"\n",
    "    resultado = {\"asesores\": [], \"equipos\": [], \"paises\": [], \"paises_por_sede\": {}, \"banderas\": {}}\n",
    "    try:\n",
    "        excel_file = pd.ExcelFile(ruta_excel)\n",
    "        if \"ME\" not in excel_file.sheet_names:\n",
    "            return resultado\n",
    "        df = pd.read_excel(ruta_excel, sheet_name=\"ME\", header=0)\n",
    "        df.columns = [str(c).strip().upper() for c in df.columns]\n",
    "        carpeta_img = os.path.join(base_path, \"IMAGEN\")\n",
    "        bandera_por_pais = {}\n",
    "        if os.path.isdir(carpeta_img):\n",
    "            for nombre_archivo in os.listdir(carpeta_img):\n",
    "                nombre_base, ext = os.path.splitext(nombre_archivo)\n",
    "                if ext.lower() in [\".jpg\", \".jpeg\", \".png\", \".webp\"]:\n",
    "                    bandera_por_pais[nombre_base.strip().upper()] = os.path.join(\"IMAGEN\", nombre_archivo).replace(\"\\\\\", \"/\")\n",
    "        def pct(valor):\n",
    "            try:\n",
    "                if pd.isna(valor):\n",
    "                    return 0\n",
    "                n = float(valor)\n",
    "                return round(n * 100 if n <= 2 else n, 2)\n",
    "            except Exception:\n",
    "                return 0\n",
    "        asesores = []\n",
    "        if all(c in df.columns for c in [\"ASESOR\", \"EQUIPOS\", \"PAISES\", \"ALCANCES\"]):\n",
    "            for _, row in df.iterrows():\n",
    "                asesor = str(row.get(\"ASESOR\", \"\")).strip() if pd.notna(row.get(\"ASESOR\", \"\")) else \"\"\n",
    "                equipo = str(row.get(\"EQUIPOS\", \"\")).strip() if pd.notna(row.get(\"EQUIPOS\", \"\")) else \"\"\n",
    "                pais = str(row.get(\"PAISES\", \"\")).strip() if pd.notna(row.get(\"PAISES\", \"\")) else \"\"\n",
    "                sede = str(row.get(\"SEDE\", \"SURCO\")).strip().upper() if pd.notna(row.get(\"SEDE\", \"SURCO\")) else \"SURCO\"\n",
    "                equipo_norm = equipo.strip().upper()\n",
    "                if not sede or sede == \"NAN\":\n",
    "                    sede = \"SURCO\"\n",
    "                if \"BPO\" in equipo_norm or sede == \"LIMA\":\n",
    "                    sede = \"BPO\"\n",
    "                elif \"SURCO\" in equipo_norm:\n",
    "                    sede = \"SURCO\"\n",
    "                if not asesor or asesor.lower() == \"nan\":\n",
    "                    continue\n",
    "                asesores.append({\"asesor\": asesor, \"equipo\": equipo, \"pais\": pais, \"sede\": sede, \"alcance\": pct(row.get(\"ALCANCES\", 0)), \"bandera\": bandera_por_pais.get(pais.upper(), \"\")})\n",
    "        equipos = []\n",
    "        if all(c in df.columns for c in [\"EQUIPOS_T\", \"ALCANCES_T\"]):\n",
    "            for _, row in df.iterrows():\n",
    "                equipo = str(row.get(\"EQUIPOS_T\", \"\")).strip() if pd.notna(row.get(\"EQUIPOS_T\", \"\")) else \"\"\n",
    "                if not equipo or equipo.lower() == \"nan\":\n",
    "                    continue\n",
    "                equipo_asesores = [a for a in asesores if a[\"equipo\"].strip().upper() == equipo.upper()]\n",
    "                paises = sorted(set(a[\"pais\"] for a in equipo_asesores if a[\"pais\"]))\n",
    "                equipos.append({\"equipo\": equipo, \"alcance\": pct(row.get(\"ALCANCES_T\", 0)), \"paises\": paises, \"bandera\": equipo_asesores[0][\"bandera\"] if equipo_asesores else \"\", \"asesores\": equipo_asesores})\n",
    "        paises_dict = {}\n",
    "        for asesor in asesores:\n",
    "            pais = asesor.get(\"pais\", \"Sin pais\") or \"Sin pais\"\n",
    "            item = paises_dict.setdefault(pais, {\"pais\": pais, \"bandera\": asesor.get(\"bandera\", \"\"), \"asesores\": []})\n",
    "            item[\"asesores\"].append(asesor)\n",
    "        paises_por_sede = {}\n",
    "        for sede in sorted(set(a.get(\"sede\", \"SURCO\") or \"SURCO\" for a in asesores)):\n",
    "            sede_paises = {}\n",
    "            for asesor in [a for a in asesores if (a.get(\"sede\", \"SURCO\") or \"SURCO\") == sede]:\n",
    "                pais = asesor.get(\"pais\", \"Sin pais\") or \"Sin pais\"\n",
    "                item = sede_paises.setdefault(pais, {\"pais\": pais, \"bandera\": asesor.get(\"bandera\", \"\"), \"asesores\": []})\n",
    "                item[\"asesores\"].append(asesor)\n",
    "            paises_por_sede[sede] = sorted(sede_paises.values(), key=lambda x: x[\"pais\"])\n",
    "        resultado[\"asesores\"] = asesores\n",
    "        resultado[\"equipos\"] = equipos\n",
    "        resultado[\"paises\"] = sorted(paises_dict.values(), key=lambda x: x[\"pais\"])\n",
    "        resultado[\"paises_por_sede\"] = paises_por_sede\n",
    "        resultado[\"banderas\"] = bandera_por_pais\n",
    "        print(f\"  Mundial ME: {len(asesores)} asesores, {len(equipos)} equipos, {len(paises_dict)} paises\")\n",
    "    except Exception as e:\n",
    "        print(f\"  ADVERTENCIA: no se pudo procesar la hoja ME: {e}\")\n",
    "    return resultado\n",
    "\n",
    "def extraer_base_asesores_desde_b2(df):\n",
    "    \"\"\"\n",
    "    Lee el bloque A2:J.. donde en B2 está el encabezado ASESOR_CRR.\n",
    "    Retorna lista de dicts: alias_crr, dni, fecha_inicio, supervisor, estado, alcance, recupero, meta, q_alc\n",
    "    Columnas (0-based): A=0, B=1, C=2, D=3, E=4, G=6, H=7, I=8, J=9\n",
    "    \"\"\"\n",
    "    base = []\n",
    "\n",
    "    # Validar que en B2 (fila 1, col 1) esté el header\n",
    "    if df.shape[0] < 3 or df.shape[1] < 10:\n",
    "        return base\n",
    "\n",
    "    header_b2 = str(df.iloc[1, 1]).strip() if pd.notna(df.iloc[1, 1]) else \"\"\n",
    "    if header_b2.upper() != \"ASESOR_CRR\":\n",
    "        return base\n",
    "\n",
    "    col_q_alc_base = None\n",
    "    for col_idx in range(df.shape[1]):\n",
    "        header_val = str(df.iloc[1, col_idx]).strip().upper() if pd.notna(df.iloc[1, col_idx]) else ''\n",
    "        if header_val == 'Q_ALC':\n",
    "            col_q_alc_base = col_idx\n",
    "            break\n",
    "\n",
    "    # Data empieza en fila 3 (index 2)\n",
    "    for i in range(2, len(df)):\n",
    "        alias = str(df.iloc[i, 1]).strip() if pd.notna(df.iloc[i, 1]) else \"\"\n",
    "        if not alias:\n",
    "            break\n",
    "\n",
    "        supervisor = str(df.iloc[i, 4]).strip() if pd.notna(df.iloc[i, 4]) else \"\"\n",
    "        dni = str(df.iloc[i, 7]).strip() if pd.notna(df.iloc[i, 7]) else \"\"\n",
    "        fecha_inicio = str(df.iloc[i, 8]).strip() if pd.notna(df.iloc[i, 8]) else \"\"\n",
    "\n",
    "        # ✅ NUEVO: ESTADO (CALL / VACACIONES)\n",
    "        estado = str(df.iloc[i, 9]).strip() if pd.notna(df.iloc[i, 9]) else \"\"\n",
    "        estado = estado.upper() if estado else \"CALL\"\n",
    "\n",
    "        alcance = df.iloc[i, 3] if df.shape[1] > 3 else None\n",
    "        recupero = df.iloc[i, 6] if df.shape[1] > 6 else None\n",
    "        meta = df.iloc[i, 2] if df.shape[1] > 2 else None\n",
    "        q_alc = ''\n",
    "        if col_q_alc_base is not None and col_q_alc_base < df.shape[1] and pd.notna(df.iloc[i, col_q_alc_base]):\n",
    "            q_alc = str(df.iloc[i, col_q_alc_base]).strip()\n",
    "\n",
    "        base.append({\n",
    "            \"alias_crr\": alias,\n",
    "            \"dni\": dni,\n",
    "            \"fecha_inicio\": fecha_inicio,\n",
    "            \"supervisor\": supervisor,\n",
    "            \"estado\": estado,  # ✅ NUEVO\n",
    "            \"alcance\": float(alcance) if pd.notna(alcance) else None,\n",
    "            \"recupero\": float(recupero) if pd.notna(recupero) else 0,\n",
    "            \"meta\": float(meta) if pd.notna(meta) else 0,\n",
    "            \"q_alc\": q_alc\n",
    "        })\n",
    "\n",
    "    return base\n",
    "\n",
    "def extraer_cumpleaños_de_inf(df_inf):\n",
    "    \"\"\"Extrae datos de cumpleaños específicamente de la hoja INF\"\"\"\n",
    "    \n",
    "    datos_cumpleaños = []\n",
    "\n",
    "    def norm_header(valor):\n",
    "        import unicodedata\n",
    "        texto = '' if valor is None else str(valor)\n",
    "        texto = unicodedata.normalize('NFKD', texto)\n",
    "        texto = ''.join(c for c in texto if not unicodedata.combining(c))\n",
    "        return texto.upper().strip().replace(' ', '')\n",
    "\n",
    "    encabezados = {\n",
    "        norm_header(valor): i\n",
    "        for i, valor in enumerate(df_inf.iloc[0])\n",
    "        if pd.notna(valor)\n",
    "    } if len(df_inf) else {}\n",
    "\n",
    "    col_fecha_nac = encabezados.get('FECHANACIMIENTO') or encabezados.get('FECNAC')\n",
    "    if col_fecha_nac is not None:\n",
    "        meses_nombre = {\n",
    "            1: 'ENERO', 2: 'FEBRERO', 3: 'MARZO', 4: 'ABRIL',\n",
    "            5: 'MAYO', 6: 'JUNIO', 7: 'JULIO', 8: 'AGOSTO',\n",
    "            9: 'SETIEMBRE', 10: 'OCTUBRE', 11: 'NOVIEMBRE', 12: 'DICIEMBRE'\n",
    "        }\n",
    "        col_nombre_nuevo = encabezados.get('NOMBRECOMPLETO')\n",
    "        col_alias_nuevo = encabezados.get('ALIAS')\n",
    "        col_puesto_nuevo = encabezados.get('PUESTO')\n",
    "        col_puesto_real_nuevo = encabezados.get('PUESTOREAL')\n",
    "        col_vigente = encabezados.get('VIGENTE')\n",
    "\n",
    "        for idx in range(1, len(df_inf)):\n",
    "            row = df_inf.iloc[idx]\n",
    "            if col_vigente is not None and col_vigente < len(row):\n",
    "                vigente = str(row[col_vigente]).strip().upper() if pd.notna(row[col_vigente]) else ''\n",
    "                if vigente and vigente != 'SI':\n",
    "                    continue\n",
    "\n",
    "            fecha = pd.to_datetime(row[col_fecha_nac], errors='coerce', dayfirst=True)\n",
    "            if pd.isna(fecha):\n",
    "                continue\n",
    "\n",
    "            nombre = str(row[col_nombre_nuevo]).strip() if col_nombre_nuevo is not None and col_nombre_nuevo < len(row) and pd.notna(row[col_nombre_nuevo]) else ''\n",
    "            alias = str(row[col_alias_nuevo]).strip() if col_alias_nuevo is not None and col_alias_nuevo < len(row) and pd.notna(row[col_alias_nuevo]) else nombre\n",
    "            puesto = str(row[col_puesto_nuevo]).strip().upper() if col_puesto_nuevo is not None and col_puesto_nuevo < len(row) and pd.notna(row[col_puesto_nuevo]) else 'ASESOR'\n",
    "            puesto_real = str(row[col_puesto_real_nuevo]).strip() if col_puesto_real_nuevo is not None and col_puesto_real_nuevo < len(row) and pd.notna(row[col_puesto_real_nuevo]) else alias\n",
    "\n",
    "            datos_cumpleaños.append({\n",
    "                'alias': alias,\n",
    "                'puesto_real': puesto_real,\n",
    "                'nombre': nombre,\n",
    "                'puesto': puesto if puesto in {'ASESOR', 'STAFF'} else 'ASESOR',\n",
    "                'mes': meses_nombre.get(int(fecha.month), ''),\n",
    "                'dia': int(fecha.day)\n",
    "            })\n",
    "\n",
    "        return datos_cumpleaños\n",
    "    \n",
    "    # POSICIONES FIJAS - según tu estructura exacta\n",
    "    col_alias = 0       # Columna A - Alias (se mantiene para referencia)\n",
    "    col_puesto_real = 1 # Columna B - PUESTO REAL (NUEVO)\n",
    "    col_nombre = 3      # Columna D - Nombre completo\n",
    "    col_puesto = 4      # Columna E - PUESTO (ASESOR/STAFF)\n",
    "    col_mes = 5         # Columna F - Mes\n",
    "    col_dia = 6         # Columna G - Día\n",
    "    \n",
    "    # Saltar 2 encabezados: grupo y FEC_NAC\n",
    "    fila_inicio = 2  # Fila 3 en Excel (0-indexed: 0=header1, 1=header2, 2=primer dato)\n",
    "    \n",
    "    for idx in range(fila_inicio, len(df_inf)):\n",
    "        row = df_inf.iloc[idx]\n",
    "        \n",
    "        # Extracción directa\n",
    "        alias = str(row[col_alias])\n",
    "        puesto_real = str(row[col_puesto_real]) if col_puesto_real < len(row) else \"\"  # NUEVO\n",
    "        nombre = str(row[col_nombre])\n",
    "        puesto = str(row[col_puesto])  # Ya viene como \"ASESOR\" o \"STAFF\"\n",
    "        mes = str(row[col_mes])        # Ya viene como \"ENERO\", \"FEBRERO\", etc.\n",
    "        dia_valor = row[col_dia]\n",
    "        if hasattr(dia_valor, 'day'):\n",
    "            dia = int(dia_valor.day)\n",
    "        else:\n",
    "            fecha_dia = pd.to_datetime(dia_valor, errors='coerce', dayfirst=True)\n",
    "            dia = int(fecha_dia.day) if pd.notna(fecha_dia) else int(dia_valor)\n",
    "        \n",
    "        # Crear registro - AGREGAR puesto_real\n",
    "        cumple_data = {\n",
    "            'alias': alias,\n",
