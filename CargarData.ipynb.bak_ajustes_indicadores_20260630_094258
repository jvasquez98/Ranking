    "            'JULIO': 6, 'AGOSTO': 7, 'SETIEMBRE': 8, 'SEPTIEMBRE': 8, \n",
    "            'OCTUBRE': 9, 'NOVIEMBRE': 10, 'DICIEMBRE': 11\n",
    "        }};\n",
    "        return meses[mes.toUpperCase()] || 0;\n",
    "    }}\n",
    "    \n",
    "    // Event listeners para slider e input (sin llamadas a funciones inexistentes)\n",
