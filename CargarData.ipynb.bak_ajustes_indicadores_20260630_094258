    "                \n",
    "                      return lineas;\n",
    "                    }}\n",
    "                  }}\n",
    "                }},\n",
    "                legend: {{\n",
    "                    position: 'top',\n",
    "                    labels: {{ font: {{ size: 12 }} }}\n",
    "                }}\n",
    "            }},\n",
    "            scales: {{\n",
