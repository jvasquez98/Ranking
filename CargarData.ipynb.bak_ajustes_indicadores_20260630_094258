    "                top: {{ style: 'thin', color: {{ argb: 'FFD0D0D0' }} }},\n",
    "                bottom: {{ style: 'thin', color: {{ argb: 'FFD0D0D0' }} }},\n",
    "                left: {{ style: 'thin', color: {{ argb: 'FFD0D0D0' }} }},\n",
    "                right: {{ style: 'thin', color: {{ argb: 'FFD0D0D0' }} }}\n",
