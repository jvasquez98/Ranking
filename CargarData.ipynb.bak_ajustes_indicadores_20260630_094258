    "    \n",
    "      if (!datosMeses[periodoCompleto]) return;\n",
    "    \n",
    "      const asesores = datosMeses[periodoCompleto];\n",
    "      const supervisores = [...new Set(asesores.map(a => a.supervisor).filter(s => s))].sort();\n",
    "      const supervisorActivoValido = (\n",
    "        supervisorFiltroActual &&\n",
