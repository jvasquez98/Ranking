    "    }}\n",
    "    \n",
    "    function abrirModalGraficaAlcances(tipo, periodoCompleto) {{\n",
    "        const modal = document.getElementById('modalGraficaAlcances');\n",
    "        const modalCanvasId = 'modalCanvasGraficaAlcances';\n",
    "        if (modal) {{\n",
