    "          font-weight: 900;\n",
    "        }}\n",
    "\n",
    "        /* Selectores alineados al ancho real de la tabla */\n",
    "        #cardTablaComparativa4M .tabla4m-selectores {{\n",
    "          display: grid;\n",
    "          grid-template-columns: repeat(4, minmax(120px, 1fr));\n",
