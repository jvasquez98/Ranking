    "        if (sup1) sup1.addEventListener('change', _refrescar);\n",
    "        if (sup2) sup2.addEventListener('change', _refrescar);\n",
    "        if (sup3) sup3.addEventListener('change', _refrescar);\n",
    "        \n",
    "        // Primer render\n",
    "        _refrescar();\n",
    "    }}\n",
