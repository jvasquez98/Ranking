    "            if (porcentaje <= 80) return '#6A1B9A';\n",
    "            if (porcentaje <= 100) return '#4A148C';\n",
    "            return '#38006B';\n",
    "        }});\n",
    "    \n",
    "        // Estilos base del canvas (sin forzar tamaño fijo)\n",
