    "        \n",
    "        // Calcular línea de tendencia (regresión lineal simple)\n",
    "        const tendencia = calcularLineaTendencia(alcancesPorMes);\n",
    "\n",
    "        let options = {{\n",
    "            responsive: true,\n",
