    "\n",
    "    function onSimMesObjetivoInput(periodoCompleto, objetivoPctMes) {{\n",
    "      const kMes = _keyMes(periodoCompleto);\n",
    "      window.__simAlcancesState[kMes] = window.__simAlcancesState[kMes] || {{}};\n",
    "    \n",
