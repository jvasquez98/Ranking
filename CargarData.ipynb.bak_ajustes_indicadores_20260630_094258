    "              const formattedValue = porcentajeAlcance.toFixed(1) + '%';\n",
    "    \n",
    "              // ✅ En modal puedes subir un poco el tamaño si quieres\n",
    "              const fontSize = (view === 'modal') ? 16 : 15;\n",
