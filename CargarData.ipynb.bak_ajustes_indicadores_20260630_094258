    "          width: fit-content;\n",
    "          max-width: 100%;\n",
    "          padding-left: 64px;\n",
    "        }}\n",
    "        \n",
    "        #cardTablaComparativa4M .tabla4m-selectores select {{\n",
    "          width: 170px;\n",
    "        }}\n",
    "\n",
    "        .mini-chart-card {{\n",
    "          background:#fff;\n",
    "          border:1px solid #e6eaf0;\n",
    "          border-radius:14px;\n",
    "          padding:10px;\n",
