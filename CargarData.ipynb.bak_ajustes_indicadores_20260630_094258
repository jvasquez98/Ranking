    "    \n",
    "            <div class=\"asesor-porcentaje ${{pctClass}}\">${{pctTxt}}</div>\n",
    "          </div>\n",
    "        `;\n",
    "      }});\n",
    "    \n",
    "      cont.innerHTML = html || `\n",
    "        <div style=\"padding:18px; text-align:center; color:#666;\">\n",
    "          Sin registros\n",
    "        </div>\n",
    "      `;\n",
    "    }}\n",
    "\n",
    "    function _getNDesdeVistaEvaluacion() {{\n",
    "      if (vistaEvaluacion === '12M') return 12;\n",
    "      if (vistaEvaluacion === '6M') return 6;\n",
    "      return 3; // default 3M\n",
